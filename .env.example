# Copy to .env and fill in values
DATABASE_URL=sqlite+aiosqlite:///data/swarmer.db
K8S_IN_CLUSTER=false

# Secret key for Fernet encryption and session cookies
# Generate with: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# If not set, a key is auto-generated and persisted to auth/secret.key
SWARMER_SECRET_KEY=

# K8s API server URL (for non-in-cluster deployments)
K8S_API_URL=https://kubernetes.default.svc

# OpenShift OAuth server URL (leave empty for K3s/Kind)
OPENSHIFT_OAUTH_URL=
# Explicit OAuth callback base URL (leave empty to auto-detect from request)
REDIRECT_BASE_URL=
HOST=0.0.0.0
PORT=8080

# Image used when launching session pods
# Set via sync-images target: make sync-images
AGENT_IMAGE_OPENCODE=
DEFAULT_AGENT_TOOL=opencode
# Optional: image pull secret name in the workspace namespace
AGENT_IMAGE_PULL_SECRET=
# Optional: pull policy (default IfNotPresent)
AGENT_IMAGE_PULL_POLICY=IfNotPresent
# Optional: force all workspaces into a single K8s namespace
K8S_NAMESPACE=
# Maximum number of concurrent agent pods (pending+running) across all workspaces.
# When the limit is reached, sessions queue instead of failing. Set to 0 to disable.
MAX_CONCURRENT_AGENTS=5
# Completed prompt-mode runs kept per session in run history (includes logs).
# Oldest runs are pruned when exceeded. Set to 0 for unlimited history.
SESSION_RUN_HISTORY_LIMIT=100
# Max age (days) of completed runs kept per session in run history.
# Applied together with SESSION_RUN_HISTORY_LIMIT — whichever prunes more wins.
# Set to 0 to disable age-based pruning.
SESSION_RUN_HISTORY_MAX_AGE_DAYS=7

# --- OpenShell integration ---
# OpenShell replaces K8s pod/Secret management (ACM-34850). K8s pod path
# will be removed once migration is complete (ACM-34863).
OPENSHELL_GATEWAY_URL=
OPENSHELL_SUPERVISOR_URL=
# TLS client cert/key/CA for OpenShell mTLS (leave empty to skip mTLS)
OPENSHELL_TLS_CERT=
OPENSHELL_TLS_KEY=
OPENSHELL_TLS_CA=
# Bearer token for OpenShell API authentication
OPENSHELL_BEARER_TOKEN=
# Seconds between sandbox garbage-collection sweeps (default 300)
SANDBOX_GC_INTERVAL=300

# --- Model presets (ACM-37232) ---
# Claude/Gemini preset -> model-ID mappings. Edit these directly (no code change
# or image rebuild needed) when Vertex AI / Google ship new model versions.
# Also set in k8s/swarmer/deployment.yaml for cluster deployments.
CLAUDE_PRESET_PLAN_MODEL=google-vertex-anthropic/claude-opus-4-6@default
CLAUDE_PRESET_BUILD_MODEL=google-vertex-anthropic/claude-sonnet-5@default
CLAUDE_PRESET_SMALL_MODEL=google-vertex-anthropic/claude-haiku-4-5@20251001
GEMINI_PRESET_PLAN_MODEL=google/gemini-3.1-pro-preview
GEMINI_PRESET_BUILD_MODEL=google/gemini-3.5-flash
GEMINI_PRESET_SMALL_MODEL=google/gemini-3.1-flash-lite
# Enables the opencode plan agent so the PLAN-role model above is actually used
OPENCODE_EXPERIMENTAL_PLAN_MODE=true
